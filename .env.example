# Lingo Sniper Environment Variables
# Copy this file to .env and adjust values for your environment

# ─── Database ───
POSTGRES_DB=lingodb
POSTGRES_USER=lingouser
POSTGRES_PASSWORD=change-me-in-production
DB_URL=postgres://lingouser:change-me-in-production@postgres:5432/lingodb?sslmode=disable

# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── JWT ───
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-32

# ─── Server ───
PORT=8080
GIN_MODE=release

# ─── CORS & WebSocket Origins ───
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_WS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Logging ───
LOG_LEVEL=info
LOG_FORMAT=json

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/api
